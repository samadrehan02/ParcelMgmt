# Copy this file to .env and fill in real values before running the server.
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# SECURITY - REQUIRED FOR PRODUCTION
# =============================================================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Use a different secret key for each environment
SECRET_KEY=replace-me-with-a-strong-random-secret

# =============================================================================
# CORS - Allowed Frontend Origins
# =============================================================================

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://myapp.com
ALLOWED_ORIGINS=http://localhost:8000

# =============================================================================
# DEFAULT USER PASSWORDS (CHANGE IN PRODUCTION!)
# =============================================================================

# Password for the default admin user (username: admin)
# Must be at least 8 characters with uppercase, lowercase, and number
ADMIN_PASSWORD=ChangeMe123!

# Password for the default demo user (username: demo)
DEMO_PASSWORD=DemoUser123!

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# 1. Generate a new SECRET_KEY using the command above
# 2. Change ADMIN_PASSWORD and DEMO_PASSWORD from defaults
# 3. Set ALLOWED_ORIGINS to your actual frontend domain(s)
# 4. Ensure .env is in .gitignore (it should be by default)
# 5. Use HTTPS in production
